datasource db {
  provider = "sqlite"
  url = "file:app.db"
}

generator client {
  provider = "comon_orm"
  output = "lib/generated"
  sqliteHelper = "flutter"
}

model Todo {
  id        Int      @id @default(autoincrement())
  title     String
  done      Boolean  @default(false)
  createdAt DateTime
}
